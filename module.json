{
  "id": "daggerheart-de",
  "title": "Daggerheart - Deutsch - Inoffiziell",
  "description": "<p>Dieses Modul bietet eine (inoffizielle) Übersetzung des Systems und der Kompendien von Daggerheart Foundryborne. Sie wurde von Fans erstellt und nutzt das Modul Babele.</p>",
  "version": "1.0",
  "url": "https://github.com/Arcadio21/daggerheart-it",
  "manifest": "https://raw.githubusercontent.com/Fenris92/daggerheart-de/main/module.json",
  "download": "https://codeload.github.com/Fenris92/daggerheart-de/zip/main",
  "compatibility": {
    "minimum": "13",
    "verified": "13"
  },
  "authors": [
    {
      "name": "Fenris92",
      "discord": "",
      "flags": {}
    }
  ],
  "relationships": {
    "requires": [
      {
        "id": "babele",
        "type": "module",
        "compatibility": {}
      }
    ],
    "systems": [
      {
        "id": "daggerheart",
        "type": "system",
        "compatibility": {
          "minimum": "1.8.0"
        }
      }
    ]
  },
  "esmodules": [
    "daggerheart-de.mjs"
  ],
  "languages": [
    {
      "lang": "de",
      "name": "Deutsch",
      "path": "lang/de-DE.json",
      "flags": {}
    }
  ],
  "flags": {
    "hotReload": {
      "extensions": [
        "css",
        "json"
      ],
      "paths": [
        "lang/"
      ]
    }
  }
}
